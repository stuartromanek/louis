# Nuxt runtime config — use NUXT_* names so values apply at container runtime
# without rebuilding the Docker image. See README.md for details.

# Get from Google Cloud Console — enable YouTube Data API v3
NUXT_YOUTUBE_API_KEY=

# From https://yoto.dev/get-started/start-here/
# Create a **public** client (PKCE). Only NUXT_YOTO_CLIENT_ID is required for self-hosting.
NUXT_YOTO_CLIENT_ID=
# Optional — only for confidential server clients (must differ from client ID).
# Leave empty for public PKCE flow (recommended).
# NUXT_YOTO_CLIENT_SECRET=

# Must match a redirect URI registered in the Yoto developer portal.
# In local dev the app derives this from the request host (localhost or LAN IP).
# Set explicitly for production deployments.
NUXT_YOTO_REDIRECT_URI=http://localhost:4000/api/yoto/auth/callback

# Optional: path to yt-dlp binary (Docker image includes it on PATH as `yt-dlp`)
# NUXT_YTDLP_PATH=yt-dlp

# Optional: Netscape cookies.txt for a throwaway YouTube account (yt-dlp --cookies).
# Downloads try anonymous first; cookies are used only after bot check / hard 403 / age-gate.
# Prefer a burner Google account. Never commit the file.
# See README.md and https://github.com/yt-dlp/yt-dlp/wiki/Extractors#exporting-youtube-cookies
# NUXT_YTDLP_COOKIES_FILE=/data/secrets/youtube-cookies.txt

# Optional: temp directory for audio extraction cache (defaults to OS tmp/yoto-cards-audio)
# Docker / docker compose default: /data/audio
# NUXT_AUDIO_WORK_DIR=/data/audio

# Optional: audio work-dir maintenance (defaults shown)
# NUXT_AUDIO_JOB_MAX_AGE_MS=3600000
# NUXT_AUDIO_CACHE_MAX_AGE_MS=1209600000
# NUXT_AUDIO_CACHE_MAX_BYTES=5368709120

# ffmpeg is required for save (yt-dlp -x). Docker installs it; native installs need ffmpeg on PATH.

# Optional: debug API routes (off by default)
# NUXT_ENABLE_DEBUG_ROUTES=true
