# Maintainer demo deployment template (Railway, Docker, etc.)
# Copy values into your platform's secret/env UI — do not commit real keys.

# Public PKCE client for the demo instance only (not secret; may be stored as a plain variable)
NUXT_YOTO_CLIENT_ID=your-demo-public-client-id

# Leave empty for public PKCE
NUXT_YOTO_CLIENT_SECRET=

# Must exactly match the demo URL registered in the Yoto developer portal
NUXT_YOTO_REDIRECT_URI=https://your-demo-domain.up.railway.app/api/yoto/auth/callback

# Set in platform secrets — never commit
NUXT_YOUTUBE_API_KEY=

NODE_ENV=production
HOST=0.0.0.0
PORT=4000

# Persistent volume mount (Railway Volume at /data/audio)
NUXT_AUDIO_WORK_DIR=/data/audio

# Show demo note in Preferences (not a top-of-app banner)
NUXT_PUBLIC_DEMO_MODE=true

# Same cookies feature as self-host — effectively required on Railway/cloud (datacenter IPs hit bot checks).
# Netscape cookies.txt for a throwaway YouTube account. Anon-first; escalate on bot/403/age-gate.
# Never commit the file. See docs/DEMO.md and README.md.
# NUXT_YTDLP_COOKIES_FILE=/data/secrets/youtube-cookies.txt

# On each Docker rebuild, pass a changing YTDLP_CACHE_BUST build-arg so pip pulls yt-dlp nightly.
# Railway: set to the deployment ID or a timestamp in the service build settings.
# Debug routes off on public demo
# NUXT_ENABLE_DEBUG_ROUTES=false
